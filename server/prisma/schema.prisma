generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum GroupRole {
  OWNER
  MEMBER
}

enum QuestionSetStatus {
  DRAFT
  PUBLISHED
  LOCKED
  SCORED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  YES_NO
  INPUT_ANSWER
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  passwordHash  String
  name          String?
  role          UserRole          @default(USER)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdGroups Group[]           @relation("GroupCreator")
  memberships   GroupMembership[]
  questionSets  QuestionSet[]     @relation("QuestionSetCreator")
  submissions      Submission[]
  sentInvites      Invite[] @relation("InvitedBy")
  acceptedInvites  Invite[] @relation("AcceptedBy")
}


model Group {
  id           String            @id @default(cuid())
  name         String
  description  String?
  createdById  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdBy    User              @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Restrict)
  memberships  GroupMembership[]
  questionSets QuestionSet[]
  invites      Invite[]

  @@index([createdById])
}

model GroupMembership {
  id        String    @id @default(cuid())
  groupId   String
  userId    String
  role      GroupRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model QuestionSet {
  id          String            @id @default(cuid())
  groupId     String
  createdById String
  title       String
  description String?
  weekLabel   String
  openAt      DateTime
  dueAt       DateTime
  status           QuestionSetStatus @default(DRAFT)
  scoresNeedReview Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User              @relation("QuestionSetCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questions   Question[]
  submissions Submission[]

  @@index([groupId])
  @@index([createdById])
  @@index([status])
}

model Question {
  id            String      @id @default(cuid())
  questionSetId String
  type          QuestionType
  prompt        String
  points        Int         @default(1)
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  options       QuestionOption[]
  answers       Answer[]

  @@index([questionSetId])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    Answer[]

  @@index([questionId])
}

model Submission {
  id           String           @id @default(cuid())
  userId       String
  questionSetId String
  status       SubmissionStatus @default(DRAFT)
  submittedAt  DateTime?
  gradedAt     DateTime?
  totalScore   Int          @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionSet  QuestionSet      @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  answers      Answer[]

  @@unique([userId, questionSetId])
  @@index([questionSetId])
}

model Answer {
  id               String          @id @default(cuid())
  submissionId     String
  questionId       String
  selectedOptionId String?
  textAnswer       String?
  isCorrect        Boolean?
  pointsAwarded    Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  submission       Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question         Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([submissionId, questionId])
  @@index([questionId])
}


model Invite {
  id               String       @id @default(cuid())
  email            String
  token            String       @unique
  status           InviteStatus @default(PENDING)
  expiresAt        DateTime
  groupId          String
  invitedByUserId  String
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  group            Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy        User         @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy       User?        @relation("AcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([invitedByUserId])
  @@index([acceptedByUserId])
  @@index([status])
  @@index([email])
}
