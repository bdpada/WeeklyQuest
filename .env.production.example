# WeeklyQuest production example values.
# Copy this file to .env.production, replace every placeholder with real local
# secrets, and never commit the real .env.production file.

# PostgreSQL container
POSTGRES_USER=weeklyquest_prod_user
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=weeklyquest_prod_db

# Prisma / backend database connection.
# The hostname is the docker-compose service name, not localhost.
DATABASE_URL=postgresql://weeklyquest_prod_user:replace-with-a-long-random-postgres-password@postgres:5432/weeklyquest_prod_db?schema=public

# Backend runtime
NODE_ENV=production
PORT=4000
CLIENT_ORIGIN=http://localhost
JWT_SECRET=replace-with-a-long-random-jwt-secret
COOKIE_SECRET=replace-with-a-long-random-cookie-secret
